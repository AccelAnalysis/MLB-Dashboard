# Data provider: local or supabase
VITE_DATA_PROVIDER=local

# Authentication mode: local or supabase.
# When omitted, Supabase authentication is selected automatically whenever the
# data provider is Supabase.
VITE_AUTH_MODE=local

# Supabase browser client configuration.
# Use the project URL and publishable/anon key from the selected environment.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Authentication redirects and policy controls.
# Use the deployed dashboard base URL, without query parameters or a hash.
VITE_AUTH_REDIRECT_URL=http://127.0.0.1:5173
VITE_AUTH_INVITE_FUNCTION=invite-user
VITE_AUTH_PASSWORD_MIN_LENGTH=12

# Optional shared-data controls.
VITE_ENABLE_REALTIME=true
VITE_SHARED_SYNC_DEBOUNCE_MS=750

# Server/CLI-only values must never use the VITE_ prefix and must never be
# committed. Examples for local shell, CI, or Supabase Edge Function secrets:
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_DB_PASSWORD=
# SUPABASE_SERVICE_ROLE_KEY=
# DATABASE_URL=
# AUTH_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# AUTH_INVITE_REDIRECT_URL=http://127.0.0.1:5173

# Local owner bootstrap values should be supplied only in the terminal session:
# LOCAL_OWNER_EMAIL=
# LOCAL_OWNER_PASSWORD=
# LOCAL_OWNER_NAME=
